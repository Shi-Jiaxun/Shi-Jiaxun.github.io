@article{shi2026replacement,
  title={Rising Replacement Burden and the Compression of Net Building},
  author={Shi, Jiaxun},
  year={2026},
  month={May},
  note={Working Paper},
  abstract={Across every major economy since 1950, the share of output absorbed by replacing depreciating capital, delta = CFC/Y, has risen steadily. In Japan, replacement now consumes 91 percent of gross investment, compressing net capital formation to 2.5 percent of GDP, the closest empirical approach to a replacement trap. This paper documents the rise across three data layers (US national accounts 1929 to 2025, a 180-country Penn World Table panel 1950 to 2023, and OECD STAN industry data), shows the rise is physical rather than a price artifact and invariant to the depreciation accounting method national agencies use, and decomposes it into a composition channel and a scale channel. Because the gross investment share is bounded, a rising delta tightens an accounting constraint that compresses net building. The paper stops at the net building rate; whether the compressed net building rate slows productivity growth runs through a transmission coefficient we do not identify.},
  html={https://ssrn.com/abstract=PLACEHOLDER},
  pdf={paper.pdf},
  supp={appendix.pdf},
  selected={true}
}

@unpublished{shi2026transmission,
  title={The Transmission Efficiency of Net Investment Declines with the Replacement Burden},
  author={Shi, Jiaxun},
  year={2026},
  month={May},
  note={Working Paper},
  abstract={Standard analyses estimate a single transmission elasticity from net investment to growth. We show this number is not a constant but a function of the replacement burden delta = CFC/VA, and that the function declines: a unit of net investment generates progressively less output growth as delta rises. The object estimated is deliberately second-order — the gradient of the transmission coefficient across the delta distribution, not its level — because the shape is identifiable where the level is not. The primary specification removes the one channel that could manufacture the gradient from no underlying relationship (transitory output shocks moving regime assignment and the regressor together) by estimating on value-added-free denominators, so that output enters only the outcome. The decline survives, and replicates across three independent levels of aggregation: a 31-country OECD panel (1,643 observations), an OECD STAN industry panel (9,019 observations), and a Compustat firm panel (251,130 firm-years on 23,955 firms). We claim the shape of the relationship, not its level.},
  pdf={transmission.pdf},
  supp={transmission_appendix.pdf},
  selected={true}
}

@unpublished{shi2026coordination,
  title={Coordination Maintenance and the Replacement Burden: A Structural Note},
  author={Shi, Jiaxun},
  year={2026},
  month={May},
  note={Draft},
  abstract={A structural mechanism for the empirical regularities documented in the companion papers, derived from a single primitive: the cost of maintaining a productive structure includes a coordination component whose magnitude grows superlinearly with the structure. Three results follow. First, superlinearity alone forces delta to rise and accumulation to stop where the average maintenance burden equals the savings rate — an average condition distinct from marginal exhaustion. Second, convexity of coordination maintenance drives the marginal replacement ratio downward through a channel additively separable from any diminishing-returns argument and independent of the sign of F-double-prime. Third, the level of the marginal product is not identifiable from monetary observables, because the coordination wedge that contaminates measured net building is not recorded in the accounts; this is a measure-theoretic property of the observation system, which is why the empirical companions recover shape and not level.},
  selected={true}
}
