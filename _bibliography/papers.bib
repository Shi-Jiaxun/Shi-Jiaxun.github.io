@article{shi2026replacement,
  title={Rising Replacement Burden and the Compression of Net Building},
  author={Shi, Jiaxun},
  year={2026},
  month={May},
  note={Working Paper},
  abstract={Across every major economy since 1950, the share of output absorbed by replacing depreciating capital, delta = CFC/Y, has risen steadily. In Japan, replacement now consumes 91 percent of gross investment, compressing net capital formation to 2.5 percent of GDP, the closest empirical approach to a replacement trap. This paper documents the rise across three data layers (US national accounts 1929 to 2025, a 180-country Penn World Table panel 1950 to 2023, and OECD STAN industry data), shows the rise is physical rather than a price artifact and invariant to the depreciation accounting method national agencies use, and decomposes it into a composition channel and a scale channel. Because the gross investment share is bounded, a rising delta tightens an accounting constraint that compresses net building. The paper stops at the net building rate; whether the compressed net building rate slows productivity growth runs through a transmission coefficient we do not identify.},
  html={https://ssrn.com/abstract=PLACEHOLDER},
  pdf={paper.pdf},
  selected={true}
}
