{%- comment -%}
  Local override of al_folio_core's bib.liquid, rewritten for the warm-paper
  redesign. Each entry renders as: Title / italic metadata line / inline
  underlined action links / plain abstract (no card, no border, no fill).
  Separation between papers is handled in CSS (hairline on each <li>).
{%- endcomment -%}
<div class="bib-entry" id="{{ entry.key }}">
  <!-- Title (Title Case kept — citation convention) -->
  <div class="title">{{ entry.title }}</div>

  <!-- Metadata: Author · Month Year · Note, one italic line -->
  <div class="metadata">
    {%- capture authors -%}
      {%- for author in entry.author_array -%}
        {{- author.first }} {{ author.last -}}
        {%- unless forloop.last %}, {% endunless -%}
      {%- endfor -%}
    {%- endcapture -%}
    {{- authors | strip -}}
    {%- if entry.month or entry.year %}
      · {% if entry.month %}{{ entry.month | capitalize }} {% endif -%}
      {{- entry.year }}
    {%- endif -%}
    {%- if entry.note %} · {{ entry.note }}{%- endif -%}
  </div>

  <!-- Action links: inline underlined text links (HTML / PDF / online appendix / …) -->
  {%- assign has_links = false -%}
  {%- if entry.html or entry.pdf or entry.supp or entry.doi or entry.arxiv or entry.code or entry.website -%}
    {%- assign has_links = true -%}
  {%- endif -%}
  {%- if has_links -%}
    <div class="links">
      {%- if entry.html -%}
        <a
          class="paper-link"
          href="{% if entry.html contains '://' %}{{ entry.html }}{% else %}{{ entry.html | prepend: '/assets/html/' | relative_url }}{% endif %}"
          >HTML</a
        >
      {%- endif -%}
      {%- if entry.pdf -%}
        <a
          class="paper-link"
          href="{% if entry.pdf contains '://' %}{{ entry.pdf }}{% else %}{{ entry.pdf | prepend: '/assets/pdf/' | relative_url }}{% endif %}"
          >PDF</a
        >
      {%- endif -%}
      {%- if entry.supp -%}
        <a
          class="paper-link"
          href="{% if entry.supp contains '://' %}{{ entry.supp }}{% else %}{{ entry.supp | prepend: '/assets/pdf/' | relative_url }}{% endif %}"
          >online appendix</a
        >
      {%- endif -%}
      {%- if entry.doi -%}
        <a class="paper-link" href="https://doi.org/{{ entry.doi }}">DOI</a>
      {%- endif -%}
      {%- if entry.arxiv -%}
        <a class="paper-link" href="https://arxiv.org/abs/{{ entry.arxiv }}">arXiv</a>
      {%- endif -%}
      {%- if entry.code -%}
        <a class="paper-link" href="{{ entry.code }}">Code</a>
      {%- endif -%}
      {%- if entry.website -%}
        <a class="paper-link" href="{{ entry.website }}">Website</a>
      {%- endif -%}
    </div>
  {%- endif -%}

  <!-- Abstract: plain text on the page background, no wrapper -->
  {%- if entry.abstract -%}
    <div class="abstract">
      <p>{{ entry.abstract }}</p>
    </div>
  {%- endif -%}
</div>
